{
  "name": "@veryan/lit-spa",
  "version": "0.1.4",
  "license": "MIT",
  "description": "A lib for using lit.dev as an Single Page Application",
  "author": "Veryan Goodship",
  "homepage": "https://veryan.ca",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Veryan4/lit-spa.git"
  },
  "bugs": {
    "url": "https://github.com/Veryan4/lit-spa/issues"
  },
  "keywords": [
    "webcomponent",
    "lit",
    "ts",
    "typescript",
    "spa"
  ],
  "main": "./dist/lit-spa.cjs",
  "module": "./dist/lit-spa.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lit-spa.js",
      "require": "./dist/lit-spa.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --mode=dev",
    "build-lib": "tsc && vite build --mode lib",
    "build": "tsc && vite build",
    "lint": "eslint --ext .ts --ignore-path .gitignore --fix src",
    "format": "prettier . --write",
    "test": "jest src"
  },
  "devDependencies": {
    "@types/jest": "27.0.1",
    "@types/node": "^18.11.18",
    "@typescript-eslint/eslint-plugin": "5.12.0",
    "@typescript-eslint/parser": "5.12.0",
    "babel-eslint": "^10.1.0",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-lit": "^1.6.1",
    "eslint-plugin-wc": "^1.3.2",
    "jest": "27.1.0",
    "prettier": "2.3.2",
    "ts-jest": "27.0.5",
    "typescript": "4.3.2",
    "vite": "4.3.5",
    "vite-plugin-dts": "^1.7.1",
    "@web/rollup-plugin-copy": "0.3.0",
    "@web/rollup-plugin-html": "1.10.1",
    "rollup-plugin-minify-html-literals": "1.2.6",
    "rollup-plugin-summary": "1.3.0",
    "rollup-plugin-terser": "7.0.2",
    "@rollup/plugin-node-resolve": "13.1.3",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-eslint": "^1.8.1"
  },
  "dependencies": {
    "lit": "2.6.1"
  }
}
